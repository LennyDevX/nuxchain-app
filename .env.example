# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║ 5. SOLANA BLOCKCHAIN Integration (for NFT minting on Solana)              ║
# ║    Token address & cluster endpoints                                      ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# NUX token mint address (Solana)
VITE_NUX_MINT_ADDRESS=AV9fNPXeLhyqGangnEdBkL355mqDbAi3gWU4AfzDcPZK

# Solana RPC endpoints (for NFT reads)
VITE_SOLANA_RPC_QUICKNODE=https://solana-mainnet.g.alchemy.com/v2/your_api_key
