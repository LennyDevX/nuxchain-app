# Pinata IPFS Configuration
# Get your JWT from: https://app.pinata.cloud/ > API Keys > Create New Key
# Required permissions: pinFileToIPFS, pinJSONToIPFS
VITE_PINATA_JWT=your_pinata_jwt_here
VITE_PINATA_GATEWAY=https://gateway.pinata.cloud

# Hashes and Block Numbers

# Environment
VITE_NODE_ENV=development
NODE_ENV=development

# Firebase Configuration
VITE_FIREBASE_MEASUREMENT_ID=your_firebase_measurement_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
VITE_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_AD=your_firebase_app_domain
VITE_FIREBASE=your_firebase_api_key

# Alchemy Configuration - FIXED
VITE_ALCHEMY=your_alchemy_api_key
VITE_CHAIN_ID=137

# SWAP API Key
