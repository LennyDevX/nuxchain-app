# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║ 6. API ENDPOINTS: Development vs Production                               ║
# ║    Points frontend to correct server (local dev or Vercel production)      ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# --- Development (Local) ---
# Frontend calls localhost:3002 (local API server)
VITE_API_BASE_URL=http://localhost:3002
VITE_SERVER_URL=http://localhost:3002/server

# Market data API (local)
VITE_MARKET_API_URL=http://localhost:3003

# --- Production (Vercel Serverless) ---
# Frontend uses relative paths (Vercel handles routing)
VITE_PROD_API_BASE_URL=/api
VITE_PROD_SERVER_URL=/server

# CoingeckoAPI URL (external market data)
VITE_COINGECKO_API_URL=https://api.coingecko.com/api/v3


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║ 7. THIRD-PARTY API KEYS (Backend Only - NO VITE PREFIX)                  ║
# ║    ⚠️  These should NEVER be exposed to the frontend                       ║
# ║    Store in Vercel Secrets: https://vercel.com/docs/projects/environment- ║
# │    -variables#encryption-for-environment-variables                         ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# Gemini AI (for chat/assistant features)
# Get from: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key

# Gemini Embedding Model
# gemini-embedding-2-preview  → New (multimodal, 3072D) [DEFAULT - recommended]
# gemini-embedding-001 → Legacy (text-only, 1536D) [use for rollback]
# Rollback: .\scripts\rollback-embedding.ps1 -ToV1
GEMINI_EMBEDDING_MODEL=gemini-embedding-2-preview

# Embedding vector dimensions (Matryoshka: 768 | 1536 | 3072)
# 3072 = max precision (default), 768 = cost-efficient
GEMINI_EMBEDDING_DIMENSIONS=3072

# Feature flag — set to 'false' to force rollback to gemini-embedding-001
USE_EMBEDDING_V2=true

# Vercel Blob (for chat image attachments — multimodal AI)
# Get from: https://vercel.com/docs/storage/vercel-blob
# Create a store in your Vercel project dashboard → Storage → Blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxx

# Google Custom Search API (for web search in chat)
# Get from: https://console.developers.google.com/
GOOGLE_SEARCH_API_KEY=your_google_search_api_key
GOOGLE_SEARCH_ENGINE_ID=your_custom_search_engine_id

# Uniswap Trading API (for swap quotes)
# Get from: https://developers.uniswap.org/dashboard
UNISWAP_API_KEY=your_uniswap_api_key

# PolygonScan API (for on-chain verification)
POLYGONSCAN_API_KEY=your_polygonscan_api_key


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║ 8. SECURITY & AUTHENTICATION                                              ║
# ║    Passwords, tokens, and shared secrets                                   ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# Admin password (protects admin endpoints)
# Used for: /api/admin routes, system configuration
VITE_ADMIN_PASSWORD=your_secure_admin_password
ADMIN_PASSWORD=your_secure_admin_password

# Server-to-server API key (authentication for internal APIs)
# Send in Authorization header: Authorization: Bearer {key}
SERVER_API_KEY=your_secure_server_api_key

# Session secret (for JWT/cookie signing)
SESSION_SECRET=your_session_secret_here

# Allowed origins (CORS validation)
# Comma-separated list of allowed frontend domains
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║ 9. CONTENT PROTECTION & BOT PREVENTION                                    ║
# ║    hCaptcha and Turnstile for human verification                          ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# --- hCaptcha Configuration ---
# Get credentials at: https://dashboard.hcaptcha.com/
# VITE_HCAPTCHA_SITE_KEY: Frontend only (public)
VITE_HCAPTCHA_SITE_KEY=10000000-ffff-ffff-ffff-000000000001

# HCAPTCHA_SECRET_KEY: Backend only (private - NO VITE prefix)
HCAPTCHA_SECRET_KEY=0x0000000000000000000000000000000000000000

# --- Cloudflare Turnstile Configuration ---
# Get credentials at: https://dash.cloudflare.com/
# VITE_TURNSTILE_SITE_KEY: Frontend only (public)
VITE_TURNSTILE_SITE_KEY=0x4AAAAAAClF-6RNnsPVBjaa

# TURNSTILE_SECRET_KEY: Backend only (private - NO VITE prefix)
TURNSTILE_SECRET_KEY=0x4AAAAAAClF-6QVlnnpOcFzeLoh6Po7GlI


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║ 10. IPFS & DECENTRALIZED STORAGE                                          ║
# ║     Pinata for NFT metadata & file uploads                                 ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# Pinata API Key (ID for tracking)
# Get from: https://app.pinata.cloud/developers/api-keys
VITE_PINATA=your_pinata_api_key

# Pinata JWT Token (authentication for file uploads)
# ⚠️  Backend only (NO VITE prefix) — frontend calls /api/ipfs/upload
PINATA_JWT=your_pinata_jwt_token

# Pinata Secret Key
# ⚠️  Backend only — for JWT generation
VITE_PINATA_SK=your_pinata_secret_key

# Pinata Gateway URL (for accessing stored files)
VITE_PINATA_GATEWAY=https://gateway.pinata.cloud


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║ 11. WALLET INTEGRATION                                                    ║
# ║     WalletConnect, MetaMask configuration                                 ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# WalletConnect/Reown Project ID (for multi-chain wallet connections)
# Get from: https://cloud.walletconnect.com/
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║ 12. DEX & SWAP INTEGRATION                                                ║
# ║     DODO, UniswapAPI for token swaps                                      ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# DODO DEX API Key (for swap/liquidity data)
VITE_SWAP_DODOEX=your_dodoex_api_key


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║ 13. CACHING & DISTRIBUTED SYSTEMS                                         ║
# ║     Redis for session/data caching                                        ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# Redis connection URL (Upstash for serverless environments)
# Format: redis://default:{password}@{host}:{port}
REDIS_URL=redis://default:your_redis_password@redis-url:6379
nuxchaindb_REDIS_URL=redis://default:your_redis_password@redis-url:6379


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║ 14. BUILD & DEPLOYMENT TOOLS                                              ║
# ║     Vercel, Turborepo configuration                                       ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# NX/Turborepo: Enable daemon for faster rebuilds
NX_DAEMON=false

# Turborepo remote caching (for CI/CD speed)
TURBO_CACHE=remote:rw
TURBO_DOWNLOAD_LOCAL_ENABLED=true
TURBO_REMOTE_ONLY=true
TURBO_RUN_SUMMARY=true

# Vercel environment indicator (set by Vercel automatically)
# VERCEL=1
# VERCEL_ENV=production
# VERCEL_TARGET_ENV=production


