# Contract Addresses
VITE_STAKING_ADDRESS_V2=0x0000000000000000000000000000000000000000
VITE_AIRDROP_ADDRESS=0x0000000000000000000000000000000000000000
VITE_TREASURY_ADDRESS=0x0000000000000000000000000000000000000000
VITE_MARKETPLACE_ADDRESS=0x0000000000000000000000000000000000000000

# Airdrop Factory Contract (actualizar con la dirección real después del deploy)
VITE_AIRDROP_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000

# Pinata IPFS Configuration
# Get your JWT from: https://app.pinata.cloud/ > API Keys > Create New Key
# Required permissions: pinFileToIPFS, pinJSONToIPFS
# IMPORTANT: Use PINATA_JWT (no VITE_ prefix) — this key must stay server-side only.
# The frontend calls /api/ipfs/upload which uses this key server-side.
PINATA_JWT=your_pinata_jwt_here
VITE_PINATA_GATEWAY=https://gateway.pinata.cloud

# Hashes and Block Numbers

# Environment
VITE_NODE_ENV=development
NODE_ENV=development

# Firebase Configuration
VITE_FIREBASE_MEASUREMENT_ID=your_firebase_measurement_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
VITE_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_AD=your_firebase_app_domain
VITE_FIREBASE=your_firebase_api_key

# Alchemy Configuration - FIXED
VITE_ALCHEMY=your_alchemy_api_key
VITE_CHAIN_ID=137

# SWAP API Key
VITE_SWAP_DODOEX=your_dodoex_api_key

# Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Server API Key for authentication
SERVER_API_KEY=your_server_api_key_here

# API Configuration for Development
VITE_API_BASE_URL=http://localhost:3002
VITE_SERVER_URL=http://localhost:3002/server

# Production API Configuration (Vercel Serverless)
# Use relative paths for serverless functions
VITE_PROD_API_BASE_URL=/api
VITE_PROD_SERVER_URL=/server

# Port for local development
PORT=3002

# Google Search API Configuration
# Get your API key from: https://console.developers.google.com/
# Create a Custom Search Engine at: https://cse.google.com/
GOOGLE_SEARCH_API_KEY=your_google_search_api_key_here
GOOGLE_SEARCH_ENGINE_ID=your_custom_search_engine_id_here



# hCaptcha Configuration (Anti-Bot Protection)
# Get your site key and secret at: https://dashboard.hcaptcha.com/
# VITE_HCAPTCHA_SITE_KEY goes in frontend (public)
# HCAPTCHA_SECRET_KEY stays server-side only (never use VITE_ prefix)
VITE_HCAPTCHA_SITE_KEY=10000000-ffff-ffff-ffff-000000000001
HCAPTCHA_SECRET_KEY=0x0000000000000000000000000000000000000000

# Solana RPC Endpoints
SOLANA_RPC_QUICKNODE=your_quicknode_solana_rpc_url
SOLANA_RPC=https://api.mainnet-beta.solana.com

# WalletConnect/Reown Project ID
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Uniswap Developer API Key (backend only - never use VITE_ prefix)
# Get your key at: https://developers.uniswap.org/dashboard
UNISWAP_API_KEY=your_uniswap_api_key_here


