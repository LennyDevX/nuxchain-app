#┌─────────────────────────────────────────────────────────────────────────────┐
#│ NuxChain Environment Configuration (.env)                                    │
#│ Organize by category for clarity and maintainability                         │
#└─────────────────────────────────────────────────────────────────────────────┘

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║ 1. ENVIRONMENT & DEPLOYMENT                                              ║
# ║    Control app behavior by environment (dev/production)                   ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# Frontend environment flag (development | production)
VITE_NODE_ENV=development

# Backend environment (controls logging level, error reporting)
NODE_ENV=development

# Local development port (ignored on Vercel)
PORT=3002

# Optional: Vercel deployment environment flags
# VERCEL=1
# VERCEL_ENV=production
# VERCEL_TARGET_ENV=production


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║ 2. FIREBASE (Backend Database & Authentication)                          ║
# ║    https://console.firebase.google.com/                                  ║
# ║    ⚠️  Sensitive: FIREBASE_*_ACCOUNT contains private keys (backend only) ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# Firebase Project Identifier
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id

# Firebase Authentication Domain
VITE_FIREBASE_AUTH_DOMAIN=your_firebase_project.firebaseapp.com

# Firebase Storage Bucket (images, documents)
VITE_FIREBASE_STORAGE_BUCKET=your_firebase_project.firebasestorage.app

# Firebase Web API Key (public, used by frontend)
VITE_FIREBASE_API_KEY=your_firebase_web_api_key

# Firebase App ID
VITE_FIREBASE_APP_ID=your_firebase_app_id

# Firebase Messaging ID (for push notifications)
VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id

# Firebase Analytics Measurement ID
VITE_FIREBASE_MEASUREMENT_ID=your_firebase_measurement_id

# 🔐 Server-side only: Firebase Admin Service Account (JSON)
# ⚠️  NEVER commit this! Use Vercel Secrets to sync
# Format: Full JSON string with \n escaped newlines
# Get from: Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║ 3. BLOCKCHAIN: Network Configuration & RPC                               ║
# ║    Polygon Mainnet (default) - Change for other networks                  ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# Blockchain Network (chain ID for contract interactions)
# 137 = Polygon Mainnet, 80001 = Mumbai Testnet
VITE_CHAIN_ID=137

# Network name (for UI display)
VITE_CHAIN_NAME=Polygon Mainnet
VITE_NETWORK_NAME=polygon
VITE_NETWORK_ID=137

# RPC URL (primary endpoint for blockchain reads/writes)
VITE_RPC_URL=https://polygon-rpc.com/

# Alchemy RPC API Key (alternative RPC provider with better rate limits)
VITE_ALCHEMY=your_alchemy_api_key
ALCHEMY_API_KEY=your_alchemy_api_key

# Block number for reference (updates after significant events)
VITE_BLOCK_NUMBER=83626688

# Gas cost tracking (for display/analysis)
VITE_TOTAL_GAS_POL=9.60462745785413996
VITE_TOTAL_GAS_WEI=9604627457854139960

# Deployment date (track when contracts were deployed)
VITE_DEPLOYMENT_DATE=2026-03-01T13:56:43.537Z


