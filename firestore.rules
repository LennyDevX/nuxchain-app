rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ================================================================
    // USER PROFILES - User data (username, bio, avatar, etc.)
    // ================================================================
    // Users can only read/write their own profile data
    match /users/{userId} {
      // Allow user to read their own profile
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // Allow user to create/update their own profile
      allow write: if request.auth != null && request.auth.uid == userId;
      
      // Allow deletion of own profile
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // ================================================================
    // AIRDROP REGISTRATIONS - CRITICAL SECURITY
    // ================================================================
    // Allow PUBLIC reads (count, list) but NO writes from clients
    // ALL writes must go through Cloud Function (server-side validation)
    // ================================================================
    match /nuxchainAirdropRegistrations/{document=**} {
      // Allow public reads (for counting registered users, etc.)
      allow read: if true;
      
      // DENY ALL direct writes from clients
      // All registrations MUST go through Cloud Function validation
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // ================================================================
    // RATE LIMITS - For distributed rate limiting (Feb 2026)
    // ================================================================
    match /rateLimits/{document=**} {
      // Only server can read/write (Cloud Functions and API endpoints)
      allow read: if false;
      allow write: if false;
    }

    // ================================================================
    // AUDIT LOGS - For security event logging (Feb 2026)
    // ================================================================
    match /auditLogs/{document=**} {
      // Only server can write logs
      // Admins can read (implement admin auth if needed)
      allow read: if false;  // TODO: Add admin authentication
      allow write: if false; // Only Cloud Functions write
    }

    // ================================================================
    // PENDING VERIFICATIONS - For future email verification
    // ================================================================
    match /pendingVerifications/{document=**} {
      allow read: if request.auth.uid == resource.data.userId;
      allow create: if false;  // Only Cloud Function can create
      allow update: if false;
      allow delete: if request.auth.uid == resource.data.userId;
    }

    // ================================================================
    // WALLET REGISTRATIONS - For NUX rewards wallet linking
    // ================================================================
    // Users can read/write their own wallet registration data
    // This links Polygon and Solana wallets for NUX reward claiming
    // Uses Polygon wallet address as document ID for verification
    // ================================================================
    match /walletRegistrations/{polygonAddress} {
      // Allow anyone to read wallet registrations (public data)
      allow read: if true;
      
      // Allow creation of new wallet registration
      // Validate that polygonAddress in data matches document ID
      allow create: if request.resource.data.polygonAddress != null &&
        request.resource.data.polygonAddress == polygonAddress &&
        request.resource.data.solanaAddress != null;
      
      // Allow update of existing registration
      // User can only update their own wallet registration
      allow update: if resource.data.polygonAddress == polygonAddress &&
        request.resource.data.polygonAddress == polygonAddress;
      
      // Allow deletion of own registration
      allow delete: if resource.data.polygonAddress == polygonAddress;
    }

    // ================================================================
    // LAUNCHPAD PURCHASES - Written and read exclusively by Admin SDK
    // Client reads are denied; all writes come from the purchase API.
    // ================================================================
    match /launchpadPurchases/{document=**} {
      allow read: if false;  // Admin SDK only (bypasses rules)
      allow write: if false; // API endpoint only
    }

    // ================================================================
    // CHAT CONVERSATIONS - Per-wallet conversation history
    // ================================================================
    // No Firebase Auth — app uses EVM wallets as user identifiers.
    // Allow read/write only when the path wallet address is a valid
    // Ethereum address (0x + 40 hex chars, 42 total).
    // ================================================================
    match /users/{userId}/conversations/{conversationId} {
      allow read, write: if userId.size() == 42 &&
        userId.matches('0x[a-fA-F0-9]{40}');
    }

    // ================================================================
    // DEFAULT - Deny all other access
    // ================================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ================================================================
    // SUBSCRIPTIONS - NuxBee AI subscription records
    // ================================================================
    // Users can read their own subscription (by Solana wallet address)
    // ALL writes MUST go through server-side API (purchase endpoint)
    // ================================================================
    match /subscriptions/{walletAddress} {
      // Allow user to read their own subscription status
      // Wallet address in document ID must match request param
      allow read: if true; // public read needed for frontend status checks
      
      // DENY ALL direct client writes
      // All subscription changes go through /api/subscriptions/purchase
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // ================================================================
    // CHAT USAGE - Daily usage tracking per wallet / IP
    // ================================================================
    // Server-only access (tracked via KV in Vercel, Firestore as backup)
    // ================================================================
    match /chatUsage/{document=**} {
      allow read: if false;
      allow write: if false;
    }  }
}