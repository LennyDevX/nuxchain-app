{
  "name": "nuxchain-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:gemini": "nodemon src/server/gemini/index.js",
    "dev:market": "node src/server/api-server.js",
    "dev:api": "nodemon src/server/gemini/index.js",
    "dev:server": "nodemon src/server/gemini/index.js",
    "dev:api-local": "node src/server/api-server.js",
    "build:api-local": "tsc -p tsconfig.api.json",
    "dev:full": "npm run build:api-local && concurrently --names \"VITE,GEMINI,MARKET\" -c \"cyan,green,yellow\" \"npm run dev\" \"npm run dev:gemini\" \"npm run dev:market\"",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "check-env": "node scripts/setup/check-env.js",
    "lighthouse": "lhci autorun --config=./lighthouserc.cjs",
    "lighthouse:local": "npm run build && vite preview --port 4173 & sleep 3 && lhci autorun --config=./lighthouserc.cjs && kill $!",
    "lighthouse:local:windows": "npm run build && (start /B vite preview --port 4173) && timeout /t 5 && lhci autorun --config=./lighthouserc.cjs",
    "lighthouse:edge": "powershell -ExecutionPolicy Bypass -File ./lighthouse-audit.ps1",
    "wallet:search": "node scripts/analysis/search-wallet-advanced.cjs",
    "wallet:analyze": "node scripts/analysis/bulk-wallet-analysis.cjs",
    "wallet:debug": "node scripts/analysis/wallet-debug.cjs",
    "test:api": "node scripts/analysis/test-api.cjs",
    "wallet:wipe-bots": "node scripts/maintenance/wipe-bots.cjs",
    "server:install": "cd src/server && npm install",
    "subgraph:install": "cd subgraph && npm install",
    "subgraph:codegen": "cd subgraph && npm run codegen",
    "subgraph:build": "cd subgraph && npm run build",
    "subgraph:deploy": "cd subgraph && npm run deploy",
    "subgraph:auth": "graph auth",
    "sync:abis": "node scripts/update-abis-from-export.cjs",
    "test:production": "node api/test/simple-test-runner.js",
    "test:comprehensive": "node api/test/comprehensive-chat-test.js",
    "test:readiness": "node api/test/production-ready.test.js",
    "test": "npm run test:production"
  },
  "dependencies": {
    "@apollo/client": "^3.14.0",
    "@google/genai": "^1.41.0",
    "@hcaptcha/react-hcaptcha": "^2.0.2",
    "@metamask/sdk": "^0.34.0",
    "@metaplex-foundation/mpl-token-metadata": "^3.4.0",
    "@metaplex-foundation/umi": "^1.5.1",
    "@metaplex-foundation/umi-bundle-defaults": "^1.5.1",
    "@metaplex-foundation/umi-signer-wallet-adapters": "^1.5.1",
    "@mozilla/readability": "^0.6.0",
    "@pinata/sdk": "^2.1.0",
    "@safe-global/safe-apps-provider": "^0.18.6",
    "@safe-global/safe-apps-sdk": "~9.1.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-react-ui": "^0.9.39",
    "@solana/wallet-adapter-wallets": "^0.19.37",
    "@solana/web3.js": "^1.98.4",
    "@tanstack/react-query": "^5.90.21",
    "@types/react-window": "^1.8.8",
    "@uiw/react-markdown-preview": "^5.1.5",
    "@vercel/kv": "^3.0.0",
    "@walletconnect/ethereum-provider": "~2.23.5",
    "axios": "^1.13.5",
    "buffer": "^6.0.3",
    "chalk": "^5.6.2",
    "chart.js": "^4.5.1",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "csv-stringify": "^6.6.0",
    "dotenv": "^17.3.1",
    "ethers": "^6.16.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-slow-down": "^3.0.1",
    "express-validator": "^7.3.1",
    "firebase-admin": "^13.6.1",
    "framer-motion": "^12.34.0",
    "google-auth-library": "^10.5.0",
    "graphql": "^16.12.0",
    "helmet": "^8.1.0",
    "jsdom": "^28.0.0",
    "json2csv": "^6.0.0-alpha.2",
    "pinata-web3": "^0.5.4",
    "react": "^19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.1",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.13.0",
    "react-window": "^1.8.11",
    "recharts": "^3.7.0",
    "viem": "^2.45.3",
    "wagmi": "^3.4.3",
    "winston": "^3.19.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@lhci/cli": "^0.15.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/bs58": "^4.0.4",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.13",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/serviceworker": "^0.0.189",
    "@vercel/analytics": "^1.6.1",
    "@vercel/node": "^5.6.3",
    "@vercel/speed-insights": "^1.3.1",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.24",
    "bs58": "^6.0.0",
    "concurrently": "^9.2.1",
    "csv-writer": "^1.6.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^6.1.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "firebase": "^12.9.0",
    "form-data": "^4.0.5",
    "globals": "^16.5.0",
    "node-fetch": "^3.3.2",
    "nodemon": "^3.1.11",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "terser": "^5.46.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.55.0",
    "vite": "^7.2.7",
    "vite-plugin-pwa": "^1.2.0",
    "workbox-window": "^7.4.0"
  },
  "overrides": {
    "axios": "^1.13.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
