{
  "name": "nuxchain-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "nodemon src/server/gemini/index.js",
    "dev:server": "nodemon src/server/gemini/index.js",
    "dev:full": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "check-env": "node scripts/check-env.js",
    "lighthouse": "lhci autorun --config=./lighthouserc.cjs",
    "lighthouse:local": "npm run build && vite preview --port 4173 & sleep 3 && lhci autorun --config=./lighthouserc.cjs && kill $!",
    "lighthouse:local:windows": "npm run build && (start /B vite preview --port 4173) && timeout /t 5 && lhci autorun --config=./lighthouserc.cjs",
    "lighthouse:edge": "powershell -ExecutionPolicy Bypass -File ./lighthouse-audit.ps1",
    "server:install": "cd src/server && npm install",
    "subgraph:install": "cd subgraph && npm install",
    "subgraph:codegen": "cd subgraph && npm run codegen",
    "subgraph:build": "cd subgraph && npm run build",
    "subgraph:deploy": "cd subgraph && npm run deploy",
    "subgraph:auth": "graph auth",
    "test:production": "node api/test/simple-test-runner.js",
    "test:comprehensive": "node api/test/comprehensive-chat-test.js",
    "test:readiness": "node api/test/production-ready.test.js",
    "test": "npm run test:production"
  },
  "dependencies": {
    "@apollo/client": "^3.14.0",
    "@google/genai": "^1.29.1",
    "@mozilla/readability": "^0.6.0",
    "@pinata/sdk": "^2.1.0",
    "@tanstack/react-query": "^5.90.10",
    "@types/react-window": "^1.8.8",
    "@uiw/react-markdown-preview": "^5.1.5",
    "axios": "^1.13.2",
    "buffer": "^6.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "express-slow-down": "^3.0.0",
    "express-validator": "^7.3.0",
    "framer-motion": "^12.23.24",
    "google-auth-library": "^10.5.0",
    "graphql": "^16.12.0",
    "helmet": "^8.1.0",
    "jsdom": "^27.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.66.0",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.9.5",
    "react-window": "^1.8.11",
    "viem": "^2.39.0",
    "wagmi": "^2.19.4",
    "winston": "^3.18.3",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@lhci/cli": "^0.15.1",
    "@tailwindcss/postcss": "^4.1.17",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/serviceworker": "^0.0.167",
    "@vercel/analytics": "^1.5.0",
    "@vercel/node": "^5.5.6",
    "@vercel/speed-insights": "^1.2.0",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.22",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^6.1.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "firebase": "^12.6.0",
    "globals": "^16.5.0",
    "nodemon": "^3.1.11",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.17",
    "terser": "^5.44.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.3",
    "vite": "^7.2.2",
    "vite-plugin-pwa": "^1.1.0",
    "workbox-window": "^7.3.0"
  },
  "overrides": {
    "axios": "^1.13.2"
  }
}
