{
  "name": "nuxchain-subgraph",
  "version": "0.1",
  "description": "Nuxchain Subgraph - The Graph indexer for Nuxchain smart contracts on Polygon",
  "private": true,
  "scripts": {
    "codegen": "graph codegen",
    "build": "graph build",
    "deploy": "node ./scripts/deploy-studio.mjs",
    "create-local": "graph create --node http://localhost:8020/ nux",
    "remove-local": "graph remove --node http://localhost:8020/ nux",
    "deploy-local": "graph deploy --node http://localhost:8020/ --ipfs http://localhost:5001 nux"
  },
  "dependencies": {},
  "devDependencies": {
    "@graphprotocol/graph-cli": "^0.98.0",
    "@graphprotocol/graph-ts": "^0.38.1"
  }
}
