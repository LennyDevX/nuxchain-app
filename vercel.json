{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "ignoreCommand": "git diff --quiet HEAD~ HEAD -- src/ api/ public/ package.json vercel.json vite.config.ts",
  "installCommand": "npm install --include=dev",
  "crons": [],
  "functions": {
    "api/chat/stream.ts": {
      "maxDuration": 60,
      "memory": 2048
    },
    "api/health/status.ts": {
      "maxDuration": 10,
      "memory": 256
    },
    "api/market/prices.ts": {
      "maxDuration": 10,
      "memory": 512
    },
    "api/price/pol.ts": {
      "maxDuration": 10,
      "memory": 256
    },
    "api/uniswap/prices.ts": {
      "maxDuration": 15,
      "memory": 512
    },
    "api/launchpad/verify-whitelist.ts": {
      "maxDuration": 10,
      "memory": 256
    },
    "api/launchpad/purchase.ts": {
      "maxDuration": 20,
      "memory": 512
    },
    "api/launchpad/stats.ts": {
      "maxDuration": 10,
      "memory": 256
    },
    "api/launchpad/burn-record.ts": {
      "maxDuration": 10,
      "memory": 256
    }
  },
  "rewrites": [
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, DELETE, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization, X-API-Key"
        }
      ]
    },
    {
      "source": "/api/price/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=60, s-maxage=60, stale-while-revalidate=120"
        }
      ]
    },
    {
      "source": "/api/market/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=30, s-maxage=30, stale-while-revalidate=60"
        }
      ]
    },
    {
      "source": "/api/health/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=10, s-maxage=10"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.(js|css|woff2|woff|ttf|eot|svg|ico|png|jpg|jpeg|webp|gif)$",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "CI": "true"
  }
}